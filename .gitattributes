# Normalize line endings to CRLF on Windows checkouts
* text=auto eol=crlf

# Python and HTML files explicitly
*.py text eol=crlf
*.html text eol=crlf
*.css text eol=crlf
*.js text eol=crlf
*.sql text eol=crlf
*.md text eol=crlf
*.txt text eol=crlf

# Binary files — don't touch these
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.db binary
*.key binary
